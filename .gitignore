# ============================================================
# .gitignore – SmartView OPC
# ============================================================

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
*.whl

# Virtual Environments
.venv/
venv/
env/
ENV/

# Prozessdaten (CSV-History – nicht im Repo, da potenziell groß)
data/*.csv

# Zertifikate (nie in Git einchecken!)
certs/
*.pem
*.key
*.crt
*.p12

# Umgebungsvariablen / Secrets
.env
.env.*
secrets.py

# IDE-Dateien
.vscode/
.idea/
*.sublime-*

# macOS
.DS_Store
.AppleDouble

# Windows
Thumbs.db
Desktop.ini

# Docker
.docker/

# Logs
*.log
logs/
